<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.textbook.dao.OrderReminderDao">

    <!--
       提醒列表
    -->

    <resultMap id="ReminderResultMap" type="com.textbook.model.OrderReminder">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="receiverId" column="receiver_id"/>
        <result property="senderId" column="sender_id"/>
        <result property="content" column="content"/>
        <result property="isRead" column="is_read"/>
        <result property="createdAt" column="created_at"/>

        <result property="textbookTitle" column="textbook_title"/>
        <result property="senderName" column="sender_name"/>
    </resultMap>

    <select id="findUnreadByReceiverId" resultMap="ReminderResultMap">
        SELECT r.*, o.textbook_title as textbook_title, u.name as sender_name
        FROM order_reminders r
                 LEFT JOIN orders o ON r.order_id = o.id
                 LEFT JOIN users u ON r.sender_id = u.id
        WHERE r.receiver_id = #{receiverId}
          AND r.is_read = 0
        ORDER BY r.created_at DESC
    </select>

</mapper>